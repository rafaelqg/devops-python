ystr = input("Informe um numero do dividendo: ")
xstr = input("Informe um numero do divisor: ")
try:
    x = int(xstr)
    y = int(ystr)
    resultado = y / x
    print("Resultado da divisão: ", resultado)
except ValueError as e1:
        print("Informe um valor numerico")
        print ("erro:", e1)
except ZeroDivisionError:
    print("Erro de divisao por zero")

